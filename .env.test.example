# Webhook Integration Test Configuration
# Copy this file to .env.test and fill in your URLs

# Your n8n workflow URL (for workflow execution)
TEST_WORKFLOW_URL=https://your-n8n-instance.com/webhook/workflow-id

# Your webhook URL (for webhook delivery)
TEST_WEBHOOK_URL=https://your-n8n-instance.com/webhook-test/your-webhook-id

# Example URLs:
# TEST_WORKFLOW_URL=https://n8n.example.com/webhook/abc123
# TEST_WEBHOOK_URL=https://n8n.example.com/webhook-test/xyz789
