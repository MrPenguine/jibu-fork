AWS_SECRET_ACCESS_KEY=

# Vault
VAULT_ADDR=
VAULT_TOKEN=
ENCRYPTION_MASTER_KEY=

# LLM providers
GOOGLE_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# LiveKit
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Speech
DEEPGRAM_API_KEY=
AZURE_RESOURCE_KEY=
AZURE_REGION=
AZURE_RESOURCE_ENDPOINT=
AZURE_SPEECH_TO_TEXT_ENDPOINT=
AZURE_TEXT_TO_SPEECH_ENDPOINT=
PLAYHT_USER_ID=
PLAYHT_API_KEY=
ELEVENLABS_API_KEY=

# Vector store
QDRANT_URL=
# Embedding dimension. Must match the worker's VECTOR_DIMENSION used for indexing.
# Google text-embedding-004 returns 768.
VECTOR_DIMENSION=768

# Worker
WORKER_API_URL=

# n8n (tool integration backend only — NOT the conversation brain)
N8N_URL=
N8N_API_KEY=
N8N_BASE_URL=
N8N_WEBHOOK_BASE_URL=
N8N_OPENAI_CREDENTIAL_ID=
N8N_ANTHROPIC_CREDENTIAL_ID=
N8N_GOOGLE_CREDENTIAL_ID=

# WhatsApp Cloud API (Meta Graph API) — channel: whatsapp
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Optional fallback agent used when an inbound number cannot be resolved to an agent
WHATSAPP_DEFAULT_AGENT_ID=
