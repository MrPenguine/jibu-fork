generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String                   @id // Supabase User ID
  email           String                   @unique
  emailConfirmed  Boolean                  @default(false)
  firstName       String?
  lastName        String?
  fullName        String? // Added from user_metadata.full_name
  imageUrl        String? // This will store the avatar_url/picture from Supabase
  provider        String? // Authentication provider (e.g., "google")
  providerIds     String[] // Array of provider IDs
  lastSignInAt    DateTime?
  phoneNumber     String? // From Supabase phone field
  phoneConfirmed  Boolean                  @default(false)
  isAnonymous     Boolean                  @default(false)
  metadata        Json? // For storing additional user_metadata
  lastOrgId       String? // Store the ID of the last organization the user accessed
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  memberships     OrganizationMembership[] // Relation field
  files           File[] // Reverse relation
  lastOrg         Organization?            @relation("UserLastOrg", fields: [lastOrgId], references: [id], onDelete: SetNull)
  sentInvitations Invitation[] // Invitations sent by this user
  apiKeys         ApiKey[] // API keys created by this user

  @@index([lastOrgId])
}

model Organization {
  id                   String                   @id @default(uuid())
  name                 String
  email                String?
  settings             Json? // Store organization settings as JSON
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  memberships          OrganizationMembership[] // Relation field
  credentials          Credential[] // Relation to credentials
  files                File[] // Reverse relation
  usersLastOrg         User[]                   @relation("UserLastOrg") // Users who have this as their last organization
  invitations          Invitation[] // Invitations for this organization
  apiKeys              ApiKey[] // API keys belonging to this organization
  knowledgeBases       KnowledgeBase[] // Knowledge bases belonging to this organization
  knowledgeBaseSources KnowledgeBaseSource[] // Knowledge base sources belonging to this organization
  assistants           Assistant[] // Assistants belonging to this organization
}

model OrganizationMembership {
  id             String   @id @default(uuid())
  organizationId String
  userId         String? // Optional to handle invitations for non-users
  email          String? // Store email for pending memberships with no user
  role           String
  status         String   @default("pending") // Status: "pending", "active", "revoked"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
  @@index([email])
}

model Invitation {
  id             String   @id @default(uuid())
  email          String
  organizationId String
  role           String
  token          String   @unique
  status         String   @default("pending") // Status: "pending", "accepted", "revoked", "expired"
  invitedById    String
  message        String? // Optional message to include with invitation
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  expiresAt      DateTime

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([invitedById])
  @@index([token])
  @@index([email])
}

model Credential {
  id                   String   @id @default(uuid())
  organizationId       String
  provider             String
  type                 String
  name                 String
  encryptedCredentials String
  metadata             Json?
  userId               String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider, name])
  @@index([organizationId])
}

model File {
  id              String   @id @default(uuid())
  name            String
  storageProvider String
  storageKey      String   @unique
  mimeType        String
  sizeBytes       Int
  organizationId  String
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  knowledgeBaseSources KnowledgeBaseSource[] // Relationship to knowledge base sources

  @@index([organizationId])
  @@index([userId])
}

model ApiKey {
  id             String    @id @default(uuid())
  organizationId String
  userId         String
  name           String
  prefix         String
  scopes         String[]
  createdAt      DateTime  @default(now())
  lastUsedAt     DateTime?
  revoked        Boolean   @default(false)
  isDefault      Boolean   @default(false)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([userId])
}

model KnowledgeBase {
  id             String                @id @default(uuid())
  name           String
  organizationId String
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sources        KnowledgeBaseSource[]
  chunks         ChunkMetadata[] // Relation to chunks
  assistants     Assistant[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([organizationId])
}

model KnowledgeBaseSource {
  id                String          @id @default(uuid())
  knowledgeBaseId   String
  organizationId    String
  sourceType        String          @default("file")
  sourcePointer     String // Stores File ID for sourceType='file'
  indexingStatus    String          @default("PENDING")
  hasIndexedContent Boolean         @default(false)
  knowledgeBase     KnowledgeBase   @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  file              File            @relation(fields: [sourcePointer], references: [id], onDelete: Cascade)
  chunks            ChunkMetadata[] // Relation to chunks
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([knowledgeBaseId])
  @@index([organizationId])
  @@index([sourcePointer])
}

model Assistant {
  id                         String         @id @default(uuid())
  name                       String
  organizationId             String
  organization               Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  knowledgeBaseId            String?
  knowledgeBase              KnowledgeBase? @relation(fields: [knowledgeBaseId], references: [id], onDelete: SetNull)
  voice                      Json?
  model                      Json?
  firstMessage               String?
  voicemailMessage           String?
  endCallMessage             String?
  transcriber                Json?
  endCallPhrases             String[]       @default([])
  startSpeakingPlan          Json?
  isServerUrlSecretSet       Boolean        @default(false)
  backgroundDenoisingEnabled Boolean        @default(false)
  serverMessages             String[]       @default([])
  clientMessages             String[]       @default([])
  hipaaEnabled               Boolean        @default(false)
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt

  @@index([organizationId])
  @@index([knowledgeBaseId])
}

model ChunkMetadata {
  id              String   @id @default(uuid())
  knowledgeBaseId String
  sourceId        String
  chunkIndex      Int
  vectorId        String
  textPreview     String
  textLength      Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  knowledgeBase KnowledgeBase       @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  source        KnowledgeBaseSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([knowledgeBaseId])
  @@index([sourceId])
  @@index([vectorId])
}
