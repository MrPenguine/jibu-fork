generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String                   @id // Supabase User ID
  email            String                   @unique
  emailConfirmed   Boolean                  @default(false)
  firstName        String?
  lastName         String?
  fullName         String? // Added from user_metadata.full_name
  imageUrl         String? // This will store the avatar_url/picture from Supabase
  provider         String? // Authentication provider (e.g., "google")
  providerIds      String[] // Array of provider IDs
  lastSignInAt     DateTime?
  phoneNumber      String? // From Supabase phone field
  phoneConfirmed   Boolean                  @default(false)
  isAnonymous      Boolean                  @default(false)
  metadata         Json? // For storing additional user_metadata
  lastOrgId        String? // Store the ID of the last organization the user accessed
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  memberships      OrganizationMembership[] // Relation field
  files            File[] // Reverse relation
  lastOrg          Organization?            @relation("UserLastOrg", fields: [lastOrgId], references: [id], onDelete: SetNull)
  sentInvitations  Invitation[] // Invitations sent by this user
  createdTools     Tool[] // Tools created by this user
  toolExecutions   ToolExecution[] // Tool executions performed by this user
  onboardingStatus OnboardingStatus? // Relation to onboarding status
  apiKeys          ApiKey[]

  @@index([lastOrgId])
}

model Organization {
  id                   String                   @id @default(uuid())
  name                 String
  email                String?
  settings             Json? // Store organization settings as JSON
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  memberships          OrganizationMembership[] // Relation field
  credentials          Credential[] // Relation to credentials
  files                File[] // Reverse relation
  usersLastOrg         User[]                   @relation("UserLastOrg") // Users who have this as their last organization
  invitations          Invitation[] // Invitations for this organization
  workflows            Workflow[] // Relation to workflows
  apiKeys              ApiKey[] // API keys belonging to this organization
  knowledgeBases       KnowledgeBase[] // Knowledge bases belonging to this organization
  knowledgeBaseSources KnowledgeBaseSource[] // Knowledge base sources belonging to this organization
  assistants           Assistant[] // Assistants belonging to this organization
  chats                Chat[] // All chats in this organization
  tools                Tool[] // Tools belonging to this organization
  agents               Agent[] // Agents belonging to this organization
  agentSessions        AgentSession[] // Agent sessions belonging to this organization
  n8nWorkflows         N8nWorkflow[] // N8n workflows for this organization
  folders              Folder[] // Folders belonging to this organization
}

model OrganizationMembership {
  id             String   @id @default(uuid())
  organizationId String
  userId         String? // Optional to handle invitations for non-users
  email          String? // Store email for pending memberships with no user
  role           String
  status         String   @default("pending") // Status: "pending", "active", "revoked"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
  @@index([email])
}

model Invitation {
  id             String   @id @default(uuid())
  email          String
  organizationId String
  role           String
  token          String   @unique
  status         String   @default("PENDING") // PENDING, ACCEPTED, EXPIRED, REVOKED
  invitedById    String
  message        String? // Optional message to include with invitation
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  expiresAt      DateTime

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([invitedById])
  @@index([token])
  @@index([email])
}

model Credential {
  id                   String   @id @default(uuid())
  organizationId       String
  provider             String
  type                 String
  name                 String
  encryptedCredentials String
  metadata             Json?
  userId               String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tools        Tool[] // Tools that use this credential

  @@unique([organizationId, provider, name])
  @@index([organizationId])
}

model File {
  id              String   @id @default(uuid())
  name            String
  storageProvider String
  storageKey      String   @unique
  mimeType        String
  sizeBytes       Int
  organizationId  String
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  knowledgeBaseSources KnowledgeBaseSource[] // Relationship to knowledge base sources

  @@index([organizationId])
  @@index([userId])
}

model Folder {
  id             String       @id @default(cuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agents         Agent[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model ApiKey {
  id             String       @id @default(cuid())
  name           String
  prefix         String       @unique
  scopes         String[]
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentId        String?
  agent          Agent?       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  revoked        Boolean      @default(false)
  lastUsedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([agentId])
}

model OnboardingStatus {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  version          Int      @default(1)
  createdAgent     Boolean  @default(false)
  addedTool        Boolean  @default(false)
  addedPhoneNumber Boolean  @default(false)
  ranTest          Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model KnowledgeBase {
  id             String                @id @default(uuid())
  name           String
  organizationId String
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sources        KnowledgeBaseSource[]
  chunks         ChunkMetadata[] // Relation to chunks
  assistants     Assistant[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([organizationId])
}

model KnowledgeBaseSource {
  id                String          @id @default(uuid())
  knowledgeBaseId   String
  organizationId    String
  sourceType        String          @default("file")
  sourcePointer     String // Stores File ID for sourceType='file'
  indexingStatus    String          @default("PENDING")
  hasIndexedContent Boolean         @default(false)
  knowledgeBase     KnowledgeBase   @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  file              File            @relation(fields: [sourcePointer], references: [id], onDelete: Cascade)
  chunks            ChunkMetadata[] // Relation to chunks
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([knowledgeBaseId])
  @@index([organizationId])
  @@index([sourcePointer])
}

model Assistant {
  id                         String          @id @default(uuid())
  name                       String
  organizationId             String
  n8nWorkflowId              String? // n8n integration fields
  n8nWorkflow                N8nWorkflow?    @relation(fields: [n8nWorkflowId], references: [id], onDelete: SetNull)
  organization               Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  knowledgeBaseId            String?
  knowledgeBase              KnowledgeBase?  @relation(fields: [knowledgeBaseId], references: [id], onDelete: SetNull)
  voice                      Json?
  model                      Json?
  firstMessage               String?
  voicemailMessage           String?
  endCallMessage             String?
  transcriber                Json?
  endCallPhrases             String[]        @default([])
  startSpeakingPlan          Json?
  isServerUrlSecretSet       Boolean         @default(false)
  backgroundDenoisingEnabled Boolean         @default(false)
  serverMessages             String[]        @default([])
  clientMessages             String[]        @default([])
  hipaaEnabled               Boolean         @default(false)
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt
  chats                      Chat[]
  tools                      AssistantTool[] // Tools assigned to this assistant
  agents                     Agent[] // Agents associated with this assistant

  @@index([organizationId])
  @@index([knowledgeBaseId])
  @@index([n8nWorkflowId])
}

model ChunkMetadata {
  id              String   @id @default(uuid())
  knowledgeBaseId String
  sourceId        String
  chunkIndex      Int
  vectorId        String
  textPreview     String
  textLength      Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  knowledgeBase KnowledgeBase       @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  source        KnowledgeBaseSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([knowledgeBaseId])
  @@index([sourceId])
  @@index([vectorId])
}

model Chat {
  id             String         @id @default(uuid())
  name           String? // Optional name for the chat
  organizationId String
  assistantId    String? // Optional: Can be null for agent-based chats
  agentId        String? // Optional: For agent-based chats
  workflowId     String? // Optional: For associating chats with workflows
  sessionId      String // Required: For calls: phone number, For chats: user identifier or anonymous session
  sessionType    String         @default("chat") // "chat" or "call"
  nodeType       AgentNodeType? // Store the current node type for agent workflows
  metadata       Json? // Additional metadata for the chat/call session
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assistant     Assistant?     @relation(fields: [assistantId], references: [id], onDelete: SetNull)
  agent         Agent?         @relation(fields: [agentId], references: [id], onDelete: SetNull)
  workflow      Workflow?      @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  messages      Message[]
  agentSessions AgentSession[] // Agent sessions associated with this chat

  // Updated constraints to ensure a chat is uniquely identified by either assistant+session or agent+session
  @@unique([assistantId, sessionId])
  @@unique([agentId, sessionId])
  @@index([organizationId])
  @@index([assistantId])
  @@index([agentId])
  @@index([workflowId])
  @@index([sessionId])
  @@index([sessionType])
}

model Message {
  id          String   @id @default(uuid())
  chatId      String
  content     String // The actual message content
  role        String // 'user', 'assistant', 'system'
  type        String   @default("text") // 'text', 'audio', 'transcript', etc.
  sequenceId  Int // Order of messages in the conversation
  redisStatus String?  @default("pending") // 'pending', 'synced', 'failed'
  metadata    Json? // Additional metadata about the message (e.g., audio duration, sentiment, etc.)
  createdAt   DateTime @default(now())

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([role])
  @@index([type])
  @@index([chatId, sequenceId]) // For efficient retrieval of messages in order
}

model Tool {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?
  type           String // e.g., "google.calendar.availability.check", "google.sheets.row.append"
  function       Json // Stores function name and parameters schema
  messages       Json[] // Array of message configurations
  metadata       Json? // Tool-specific configuration
  credentialId   String? // Optional reference to a credential
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String

  // Relationships
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  credential     Credential?     @relation(fields: [credentialId], references: [id], onDelete: SetNull)
  createdBy      User            @relation(fields: [createdById], references: [id])
  toolExecutions ToolExecution[]
  assistantTools AssistantTool[]
  workflowNodes  WorkflowNode[]  @relation("ToolToWorkflowNode")

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([credentialId])
  @@index([createdById])
  @@index([type])
}

model ToolExecution {
  id           String    @id @default(uuid())
  toolId       String
  status       String // "pending", "running", "completed", "failed"
  input        Json? // Input parameters for the execution
  output       Json? // Output result of the execution
  errorMessage String?
  executedById String
  executedAt   DateTime  @default(now())
  completedAt  DateTime?

  tool       Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)
  executedBy User @relation(fields: [executedById], references: [id])

  @@index([toolId])
  @@index([executedById])
  @@index([status])
}

model AssistantTool {
  id          String   @id @default(uuid())
  assistantId String
  toolId      String
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assistant Assistant @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  tool      Tool      @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([assistantId, toolId])
  @@index([assistantId])
  @@index([toolId])
}

// --- Enums for Agent ---
enum AgentNodeType {
  START
  END
  MESSAGE // Send a message (text, or for voice: TTS)
  LISTEN // Wait for user input (text, or for voice: ASR + VAD)
  CHOICE // Present options to the user (buttons for text, DTMF/spoken for voice)
  CONDITION // Branch logic based on variables or input
  SET_VARIABLE // Set/modify conversation variables
  API_CALL // Make an HTTP request
  TOOL_CALL // Execute one of your existing custom Tools
  FUNCTION_CALL // More generic than TOOL_CALL, might execute a predefined server-side function
  TRANSFER // For voice: transfer call (e.g., to SIP URI, phone number)
  RECORD // For voice: record audio
  PLAY_AUDIO // For voice: play a pre-recorded audio URL
  WORKFLOW_CALL // Execute a secondary workflow
  ASSISTANT // Use an Assistant for chat/voice interaction
}

enum WorkflowType {
  MASTER
  SECONDARY
}

// --- Agent Definition ---
model Agent {
  id             String         @id @default(uuid())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  name           String
  description    String?
  metadata       Json?
  organizationId String
  assistantId    String?
  n8nWorkflowId  String?
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assistant      Assistant?     @relation(fields: [assistantId], references: [id], onDelete: SetNull)
  n8nWorkflow    N8nWorkflow?   @relation(fields: [n8nWorkflowId], references: [id], onDelete: SetNull)
  chats          Chat[]
  sessions       AgentSession[]
  folderId       String?
  folder         Folder?        @relation(fields: [folderId], references: [id])
  apiKeys        ApiKey[]
  workflows      Workflow[]

  @@index([organizationId])
  @@index([assistantId])
  @@index([n8nWorkflowId])
}

model AgentSession {
  id             String       @id @default(uuid())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  agentId        String
  agent          Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  chatId         String?
  chat           Chat?        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  status         String       @default("active") // e.g., active, completed, failed
  currentNodeId  String?
  variables      Json?
  history        Json? // Log of executed nodes and I/O: Array<{ nodeId: string, input?: any, output?: any, timestamp: Date }>
  callSid        String? // For voice: SID from the provider

  @@index([agentId])
  @@index([chatId])
  @@index([organizationId])
}

model Workflow {
  id                 String       @id @default(uuid())
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  name               String
  description        String?
  nodes              Json // Array of FlowNode objects
  edges              Json // Array of FlowEdge objects
  isPrimary          Boolean      @default(false)
  agentId            String
  organizationId     String
  startNodeId        String? // ID of the node where execution begins
  version            Int          @default(1)
  isPublished        Boolean      @default(false)
  publishedAt        DateTime?
  workflowType       WorkflowType @default(MASTER)
  masterWorkflowId   String?
  masterWorkflow     Workflow?    @relation("SecondaryWorkflows", fields: [masterWorkflowId], references: [id], onDelete: Cascade)
  secondaryWorkflows Workflow[]   @relation("SecondaryWorkflows")
  n8nWorkflowId      String?
  n8nWorkflow        N8nWorkflow? @relation(fields: [n8nWorkflowId], references: [id], onDelete: SetNull)

  agent         Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  chats         Chat[]
  workflowNodes WorkflowNode[]
  workflowEdges WorkflowEdge[]

  @@index([agentId])
  @@index([organizationId])
}

model WorkflowNode {
  id               String         @id @default(uuid())
  workflowId       String
  type             AgentNodeType
  nodeType         AgentNodeType? // Legacy field for compatibility
  data             Json
  position         Json
  parameters       String? // Node parameters as JSON string
  toolId           String?
  incomingChoiceId String?

  workflow    Workflow       @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  tool        Tool?          @relation("ToolToWorkflowNode", fields: [toolId], references: [id], onDelete: SetNull)
  sourceEdges WorkflowEdge[] @relation("SourceNode")
  targetEdges WorkflowEdge[] @relation("TargetNode")

  @@index([workflowId])
  @@index([toolId])
}

model WorkflowEdge {
  id              String  @id @default(uuid())
  workflowId      String
  sourceId        String
  targetId        String
  sourceHandle    String?
  targetHandle    String?
  n8nSourceOutput String? // The output of the source node in n8n
  n8nTargetInput  String? // The input of the target node in n8n

  workflow Workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  source   WorkflowNode @relation("SourceNode", fields: [sourceId], references: [id], onDelete: NoAction)
  target   WorkflowNode @relation("TargetNode", fields: [targetId], references: [id], onDelete: NoAction)

  @@unique([sourceId, targetId])
  @@index([workflowId])
  @@index([sourceId])
  @@index([targetId])
}

// Enum for N8nWorkflow type (primary/secondary)
enum N8nWorkflowType {
  PRIMARY
  SECONDARY
}

// N8nWorkflow model for managing n8n workflow integration
model N8nWorkflow {
  id              String          @id @default(uuid())
  n8nWorkflowId   String          @unique // The ID of the workflow in n8n
  webhookUrl      String? // The webhook URL for this workflow
  workflowJson    Json? // The complete workflow JSON definition
  isActive        Boolean         @default(false) // Whether the workflow is active in n8n
  workflowType    N8nWorkflowType @default(PRIMARY) // Type of workflow (primary/secondary)
  lastValidatedAt DateTime        @default(now()) // Last time the workflow was validated
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Reverse relations - these are defined by the foreign keys on Assistant and Agent models
  assistants Assistant[] // Assistants that use this workflow (always PRIMARY)
  agents     Agent[] // Agents that use this workflow (can be PRIMARY or SECONDARY)
  workflows  Workflow[] // Workflows linked to this n8n workflow

  @@index([organizationId])
  @@index([n8nWorkflowId])
  @@index([isActive])
  @@index([workflowType]) // Add index for the new field
}
