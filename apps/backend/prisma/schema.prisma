generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id // Supabase User ID
  email       String   @unique
  firstName   String?
  lastName    String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  memberships OrganizationMembership[] // Relation field
  files       File[]   // Reverse relation
  // apiKeys     ApiKey[] // Add relations as models are created
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  // ownerId     String // Decide if needed, maybe just check role in membership
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  memberships OrganizationMembership[] // Relation field
  credentials Credential[] // Relation to credentials
  files       File[]   // Reverse relation
  // Add other org fields: globalWebhookUrl, etc.
}

model OrganizationMembership {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  role           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId]) // Composite unique key
  @@index([userId])
  @@index([organizationId])
}

model Credential {
  id                   String   @id @default(uuid())
  organizationId       String
  provider             String
  type                 String
  name                 String
  encryptedCredentials String
  metadata             Json?
  userId               String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider, name])
  @@index([organizationId])
}

model File {
  id               String    @id @default(uuid())
  name             String    // Original filename
  storageProvider  String    // e.g., 's3'
  storageKey       String    @unique // Unique path in storage (e.g., orgId/uuid/filename)
  mimeType         String    // e.g., 'application/pdf'
  sizeBytes        Int       // File size in bytes
  organizationId   String    // Foreign key to Org
  userId           String    // Foreign key to User
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Future relation for KnowledgeBase (Sprint KB-1)
  // knowledgeBaseSources KnowledgeBaseSource[]

  @@index([organizationId])
  @@index([userId])
} 