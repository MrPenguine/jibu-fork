generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String                   @id // Supabase User ID
  email            String                   @unique
  emailConfirmed   Boolean                  @default(false)
  firstName        String?
  lastName         String?
  fullName         String? // Added from user_metadata.full_name
  imageUrl         String? // This will store the avatar_url/picture from Supabase
  provider         String? // Authentication provider (e.g., "google")
  providerIds      String[] // Array of provider IDs
  lastSignInAt     DateTime?
  phoneNumber      String? // From Supabase phone field
  phoneConfirmed   Boolean                  @default(false)
  isAnonymous      Boolean                  @default(false)
  metadata         Json? // For storing additional user_metadata
  lastWorkspaceId        String? // Store the ID of the last organization the user accessed
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  memberships      WorkspaceMembership[] // Relation field
  files            File[] // Reverse relation
  lastWorkspace          Workspace?            @relation("UserLastWorkspace", fields: [lastWorkspaceId], references: [id], onDelete: SetNull)
  sentInvitations  Invitation[] // Invitations sent by this user
  createdTools     Tool[] // Tools created by this user
  toolExecutions   ToolExecution[] // Tool executions performed by this user
  onboardingStatus OnboardingStatus? // Relation to onboarding status
  apiKeys          ApiKey[]

  isAdmin          Boolean                  @default(false)
  adminRole        String?
  isSuspended      Boolean                  @default(false)
  suspendedAt      DateTime?
  suspensionReason String?

  adminAuditLogs   AdminAuditLog[]          @relation("AdminActions")

  @@index([lastWorkspaceId])
}

model Workspace {
  id                   String                   @id @default(uuid())
  name                 String
  email                String?
  settings             Json? // Store workspace settings as JSON
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  memberships          WorkspaceMembership[] // Relation field
  credentials          Credential[] // Relation to credentials
  files                File[] // Reverse relation
  usersLastWorkspace   User[]                   @relation("UserLastWorkspace") // Users who have this as their last workspace
  invitations          Invitation[] // Invitations for this workspace
  workflows            Workflow[] // Relation to workflows
  apiKeys              ApiKey[] // API keys belonging to this workspace
  knowledgeBases       KnowledgeBase[] // Knowledge bases belonging to this workspace
  knowledgeBaseSources KnowledgeBaseSource[] // Knowledge base sources belonging to this workspace
  chats                Chat[] // All chats in this workspace
  tools                Tool[] // Tools belonging to this workspace
  agents               Agent[] // Agents belonging to this workspace
  agentSessions        AgentSession[] // Agent sessions belonging to this workspace
  n8nWorkflows         N8nWorkflow[] // N8n workflows for this workspace
  folders              Folder[] // Folders belonging to this workspace
  webhooks             Webhook[]
  webhookInvocations   WebhookInvocation[]
  assistants           Assistant[] // Assistants belonging to this workspace

  subscription         Subscription?
  usageRecords         UsageRecord[]

  isSuspended          Boolean   @default(false)
  suspendedAt          DateTime?
  suspendedBy          String?
  suspensionReason     String?

  @@index([id])
}

model WorkspaceMembership {
  id             String   @id @default(uuid())
  workspaceId String
  userId         String? // Optional to handle invitations for non-users
  email          String? // Store email for pending memberships with no user
  role           String
  status         String   @default("pending") // Status: "pending", "active", "revoked"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
  @@index([email])
}

model Invitation {
  id             String   @id @default(uuid())
  email          String
  workspaceId String
  role           String
  token          String   @unique
  status         String   @default("PENDING") // PENDING, ACCEPTED, EXPIRED, REVOKED
  invitedById    String
  message        String? // Optional message to include with invitation
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  expiresAt      DateTime

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([invitedById])
  @@index([token])
  @@index([email])

  @@unique([email, workspaceId])
}

model Credential {
  id                   String   @id @default(uuid())
  workspaceId       String
  provider             String
  type                 String
  name                 String
  encryptedCredentials String
  metadata             Json?
  userId               String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tools        Tool[] // Tools that use this credential

  @@unique([workspaceId, provider, name])
  @@index([workspaceId])
}

model File {
  id              String   @id @default(uuid())
  name            String
  storageProvider String
  storageKey      String   @unique
  mimeType        String
  sizeBytes       Int
  workspaceId  String
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  knowledgeBaseSources KnowledgeBaseSource[] // Relationship to knowledge base sources

  @@index([workspaceId])
  @@index([userId])
}

model Folder {
  id             String       @id @default(cuid())
  name           String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  agents         Agent[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model ApiKey {
  id             String       @id @default(cuid())
  name           String
  prefix         String       @unique
  scopes         String[]
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentId        String?
  agent          Agent?       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  revoked        Boolean      @default(false)
  lastUsedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now())

  @@index([workspaceId])
  @@index([userId])
  @@index([agentId])
}

model OnboardingStatus {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  version          Int      @default(1)
  createdAgent     Boolean  @default(false)
  addedTool        Boolean  @default(false)
  addedPhoneNumber Boolean  @default(false)
  ranTest          Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model KnowledgeBase {
  id             String                @id @default(uuid())
  name           String
  workspaceId String
  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sources        KnowledgeBaseSource[]
  chunks         ChunkMetadata[] // Relation to chunks
  assistantLinks AssistantKnowledgeBase[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([workspaceId])
}

model KnowledgeBaseSource {
  id                String          @id @default(uuid())
  knowledgeBaseId   String
  workspaceId    String
  sourceType        String          @default("file")
  sourcePointer     String // Stores File ID for sourceType='file'
  indexingStatus    String          @default("PENDING")
  hasIndexedContent Boolean         @default(false)
  knowledgeBase     KnowledgeBase   @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  file              File            @relation(fields: [sourcePointer], references: [id], onDelete: Cascade)
  chunks            ChunkMetadata[] // Relation to chunks
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([knowledgeBaseId])
  @@index([workspaceId])
  @@index([sourcePointer])
}

model ChunkMetadata {
  id              String   @id @default(uuid())
  knowledgeBaseId String
  sourceId        String
  chunkIndex      Int
  vectorId        String
  textPreview     String
  textLength      Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  knowledgeBase KnowledgeBase       @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  source        KnowledgeBaseSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([knowledgeBaseId])
  @@index([sourceId])
  @@index([vectorId])
}

model Chat {
  id             String         @id @default(uuid())
  name           String? // Optional name for the chat
  workspaceId String
  agentId        String? // Optional: For agent-based chats
  workflowId     String? // Optional: For associating chats with workflows
  sessionId      String // Required: For calls: phone number, For chats: user identifier or anonymous session
  sessionType    String         @default("chat") // "chat" or "call"
  nodeType       AgentNodeType? // Store the current node type for agent workflows
  metadata       Json? // Additional metadata for the chat/call session
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  agent         Agent?         @relation(fields: [agentId], references: [id], onDelete: SetNull)
  workflow      Workflow?      @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  messages      Message[]
  agentSessions AgentSession[] // Agent sessions associated with this chat

  @@unique([agentId, sessionId])
  @@index([workspaceId])
  @@index([agentId])
  @@index([workflowId])
  @@index([sessionId])
  @@index([sessionType])
}

model Message {
  id          String   @id @default(uuid())
  chatId      String
  content     String // The actual message content
  role        String // 'user', 'assistant', 'system'
  type        String   @default("text") // 'text', 'audio', 'transcript', etc.
  sequenceId  Int // Order of messages in the conversation
  redisStatus String?  @default("pending") // 'pending', 'synced', 'failed'
  metadata    Json? // Additional metadata about the message (e.g., audio duration, sentiment, etc.)
  createdAt   DateTime @default(now())

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([role])
  @@index([type])
  @@index([chatId, sequenceId]) // For efficient retrieval of messages in order
}

model Tool {
  id             String   @id @default(uuid())
  workspaceId String
  name           String
  description    String?
  type           String // e.g., "google.calendar.availability.check", "google.sheets.row.append"
  function       Json // Stores function name and parameters schema
  messages       Json[] // Array of message configurations
  metadata       Json? // Tool-specific configuration
  credentialId   String? // Optional reference to a credential
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String

  // Relationships
  workspace   Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  credential     Credential?     @relation(fields: [credentialId], references: [id], onDelete: SetNull)
  createdBy      User            @relation(fields: [createdById], references: [id])
  toolExecutions ToolExecution[]
  assistantTools AssistantTool[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([credentialId])
  @@index([createdById])
  @@index([type])
}

model ToolExecution {
  id           String    @id @default(uuid())
  toolId       String
  status       String // "pending", "running", "completed", "failed"
  input        Json? // Input parameters for the execution
  output       Json? // Output result of the execution
  errorMessage String?
  executedById String
  executedAt   DateTime  @default(now())
  completedAt  DateTime?

  tool       Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)
  executedBy User @relation(fields: [executedById], references: [id])

  @@index([toolId])
  @@index([executedById])
  @@index([status])
}

// --- Enums for Agent ---
enum AgentNodeType {
  START
  END
  MESSAGE // Send a message (text, or for voice: TTS)
  LISTEN // Wait for user input (text, or for voice: ASR + VAD)
  CHOICE // Present options to the user (buttons for text, DTMF/spoken for voice)
  CONDITION // Branch logic based on variables or input
  SET_VARIABLE // Set/modify conversation variables
  API_CALL // Make an HTTP request
  TOOL_CALL // Execute one of your existing custom Tools
  FUNCTION_CALL // More generic than TOOL_CALL, might execute a predefined server-side function
  TRANSFER // For voice: transfer call (e.g., to SIP URI, phone number)
  RECORD // For voice: record audio
  PLAY_AUDIO // For voice: play a pre-recorded audio URL
  WORKFLOW_CALL // Execute a secondary workflow
}


// --- New Enums for Agent-level defaults ---
enum LlmProvider {
  OPENAI
  ANTHROPIC
  AZURE_OPENAI
  GOOGLE
  DEEPSEEK
  META
  XAI
  CUSTOM
}

enum LlmModelPreset {
  GPT_4O_MINI
  CLAUDE_3_5_SONNET
  CUSTOM
}

enum TtsProvider {
  OPENAI
  AZURE
  ELEVENLABS
  CUSTOM
}

enum SttProvider {
  WHISPER
  AZURE
  DEEPGRAM
  GOOGLE
  CUSTOM
}

// --- Agent Definition ---
model Agent {
  id             String         @id @default(uuid())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  name           String
  description    String?
  workspaceId    String
  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  folderId       String?
  folder         Folder?        @relation(fields: [folderId], references: [id])

  // --- Agent-level default settings (typed) ---
  llmProvider    LlmProvider?
  llmModel       String?
  ttsProvider    TtsProvider?
  ttsVoiceId     String?
  sttProvider    SttProvider?
  sttModel       String?

  // --- Call/Channel Specific Settings (moved from Assistant) ---
  firstMessage               String?
  voicemailMessage           String?
  endCallMessage             String?
  endCallPhrases             String[] @default([])
  startSpeakingPlan          Json?
  isServerUrlSecretSet       Boolean  @default(false)
  backgroundDenoisingEnabled Boolean  @default(false)
  serverMessages             String[] @default([])
  clientMessages             String[] @default([])
  hipaaEnabled               Boolean  @default(false)
  metadata                   Json? // For storing agent-specific settings, like system prompts

  // --- Optional links retained ---
  n8nWorkflowId  String?
  n8nWorkflow    N8nWorkflow?   @relation(fields: [n8nWorkflowId], references: [id], onDelete: SetNull)
  chats          Chat[]
  sessions       AgentSession[]
  usageRecords   UsageRecord[]
  apiKeys        ApiKey[]
  workflows      Workflow[]
  assistants     Assistant[] // Added back-relation to Assistant

  // --- Primary Workflow Link ---
  primaryWorkflowId String?   @unique
  primaryWorkflow   Workflow? @relation("PrimaryAgentWorkflow", fields: [primaryWorkflowId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([folderId])
}

// --- Assistant Models ---
model Assistant {
  id             String      @id @default(uuid())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Ownership and isolation
  agentId        String
  agent          Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)

  // Denormalized for tenancy scoping and fast filters
  workspaceId    String
  workspace      Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Identity and settings (can override agent defaults)
  name           String
  description    String?
  llmProvider    LlmProvider?
  llmModel       String?
  voiceId        String?
  sttModel       String?
  hipaaEnabled   Boolean     @default(false)
  systemPrompt   String?
  metadata       Json?

  // Relations
  tools          AssistantTool[]
  knowledgeBases AssistantKnowledgeBase[]

  @@unique([agentId, name])
  @@index([agentId])
  @@index([workspaceId])
}

model AssistantTool {
  id           String    @id @default(uuid())
  assistantId  String
  toolId       String
  // Optional per-assistant tool configuration
  config       Json?

  assistant    Assistant @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  tool         Tool      @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([assistantId, toolId])
  @@index([toolId])
}

model AssistantKnowledgeBase {
  id               String        @id @default(uuid())
  assistantId      String
  knowledgeBaseId  String

  assistant        Assistant     @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  knowledgeBase    KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  @@unique([assistantId, knowledgeBaseId])
  @@index([knowledgeBaseId])
}

model AgentSession {
  id             String       @id @default(uuid())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  agentId        String
  agent          Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  chatId         String?
  chat           Chat?        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  status         String       @default("active") // e.g., active, completed, failed
  currentNodeId  String?
  variables      Json?
  history        Json? // Log of executed nodes and I/O: Array<{ nodeId: string, input?: any, output?: any, timestamp: Date }>
  callSid        String? // For voice: SID from the provider

  @@index([agentId])
  @@index([chatId])
  @@index([workspaceId])
}

model Workflow {
  id                 String       @id @default(uuid())
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  name               String
  description        String?

  // Agent & Workspace relations
  agentId            String
  agent              Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  workspaceId        String
  workspace          Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Workflow classification
  isPrimary          Boolean      @default(false)

  // n8n link
  n8nWorkflowId      String?
  n8nWorkflow        N8nWorkflow? @relation(fields: [n8nWorkflowId], references: [id], onDelete: SetNull)

  // Versioning pointers
  publishedVersionId String?          @unique
  publishedVersion   WorkflowVersion? @relation("PublishedWorkflowVersion", fields: [publishedVersionId], references: [id], onDelete: SetNull)

  draftVersionId     String?          @unique
  draftVersion       WorkflowVersion? @relation("DraftWorkflowVersion", fields: [draftVersionId], references: [id], onDelete: SetNull)

  // Reverse relations
  versions           WorkflowVersion[]
  agentAsPrimary     Agent?       @relation("PrimaryAgentWorkflow")
  chats              Chat[]
  webhooks           Webhook[]

  @@index([agentId])
  @@index([workspaceId])
  @@index([n8nWorkflowId])
}

// WorkflowNode and WorkflowEdge models have been removed.

// Enum for N8nWorkflow type (primary/secondary)
enum N8nWorkflowType {
  PRIMARY
  SECONDARY
}

// N8nWorkflow model for managing n8n workflow integration
model N8nWorkflow {
  id              String          @id @default(uuid())
  n8nWorkflowId   String?         @unique // The ID of the workflow in n8n (optional until worker creates it)
  webhookUrl      String? // The webhook URL for this workflow
  workflowJson    Json? // The complete workflow JSON definition
  isActive        Boolean         @default(false) // Whether the workflow is active in n8n
  workflowType    N8nWorkflowType @default(PRIMARY) // Type of workflow (primary/secondary)
  lastValidatedAt DateTime        @default(now()) // Last time the workflow was validated
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Reverse relations - these are defined by the foreign keys on Assistant and Agent models
  agents     Agent[] // Agents that use this workflow (can be PRIMARY or SECONDARY)
  workflows  Workflow[] // Workflows linked to this n8n workflow

  @@index([workspaceId])
  @@index([n8nWorkflowId])
  @@index([isActive])
  @@index([workflowType]) // Add index for the new field
}


// New model: WorkflowVersion for versioned workflow JSON snapshots
model WorkflowVersion {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workflowId   String
  workflow     Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  version      Int
  workflowJson Json

  status       String   @default("draft") // "draft" | "published" | "archived"
  publishedAt  DateTime?

  // Back-links for pointers on Workflow
  workflowAsPublishedVersion Workflow? @relation("PublishedWorkflowVersion")
  workflowAsDraftVersion     Workflow? @relation("DraftWorkflowVersion")

  @@unique([workflowId, version])
  @@index([workflowId])
}

model Webhook {
  id             String             @id @default(uuid())
  name           String
  description    String?
  workflowId     String?            // Optional link to a workflow
  workspaceId String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  
  // Relations
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflow       Workflow?          @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  invocations    WebhookInvocation[]

  @@index([workspaceId])
  @@index([workflowId])
}

model WebhookInvocation {
  id             String   @id @default(uuid())
  webhookId      String
  payload        Json
  headers        Json
  status         String   @default("pending") // pending, completed, failed
  error          String?
  workspaceId String
  createdAt      DateTime @default(now())
  
  // Relations
  webhook        Webhook      @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([workspaceId])
  @@index([status])
}

model Plan {
  id              String         @id @default(cuid())
  name            String         // "Starter", "Pro", "Enterprise"
  priceMonthly    Float?         // null for custom enterprise plans
  priceYearly     Float?
  creditsIncluded Int            // e.g., 10_000 credits per month
  features        Json           // { "apiAccess": true, "customVoices": false }
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  subscriptions   Subscription[]
}

model Subscription {
  id               String     @id @default(cuid())
  workspaceId      String     @unique
  workspace        Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  planId           String
  plan             Plan       @relation(fields: [planId], references: [id])

  status           String     // "active", "trialing", "past_due", "canceled"
  stripeCustomerId String?    @unique
  stripeSubId      String?    @unique

  currentPeriodEnd DateTime

  // Credits / limits
  creditsUsed      Int        @default(0)
  creditsLimit     Int?

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([workspaceId])
  @@index([planId])
  @@index([status])
}

model UsageRecord {
  id             String     @id @default(cuid())

  workspaceId    String
  workspace      Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  agentId        String?
  agent          Agent?     @relation(fields: [agentId], references: [id], onDelete: SetNull)

  type           String     // "LLM_TOKENS" | "TTS_CHARACTERS" | "STT_SECONDS" | "CALL_MINUTES"
  provider       String     // "OPENAI", "ELEVENLABS", "DEEPGRAM", etc.
  modelUsed      String?    // "gpt-4o", "eleven_turbo_v2", etc.
  unitsConsumed  Float      // 1500 (tokens), 2500 (characters), 60 (seconds)
  costInMicroUSD Int        // Cost in millionths of USD (e.g., $0.01 = 10000)

  sessionId      String?    // Link to AgentSession or Chat for debugging

  timestamp      DateTime   @default(now())

  @@index([workspaceId, timestamp])
  @@index([type, timestamp])
  @@index([agentId, timestamp])
  @@index([provider, timestamp])
}

model AdminAuditLog {
  id          String   @id @default(cuid())

  adminUserId String
  adminUser   User     @relation("AdminActions", fields: [adminUserId], references: [id], onDelete: Cascade)

  action      String   // "SUSPEND_USER", "VIEW_WORKSPACE", "UPDATE_PLAN", etc.
  targetType  String?  // "User" | "Workspace" | "Plan" | ...
  targetId    String?
  details     Json?    // Additional context about the action
  ipAddress   String?
  userAgent   String?

  createdAt   DateTime @default(now())

  @@index([adminUserId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@index([action])
}
