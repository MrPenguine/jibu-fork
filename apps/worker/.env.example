# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Ollama (optional embedding backend)
# Use 11435 on Windows when the Docker Ollama container is mapped to 11435 to avoid
# clashing with a native Windows Ollama service on port 11434.
OLLAMA_URL=http://localhost:11434

# Vector DB / embeddings
# Qdrant collection dimensions are derived from the embedding model registry in
# apps/worker/src/embedding/embedding.service.ts. VECTOR_DIMENSION is only used as
# a fallback dimension for unknown/legacy models that are not in the registry.
# Default to the local Ollama embedding model instead of a cloud provider.
QDRANT_URL=http://localhost:6333
VECTOR_DIMENSION=1024
EMBEDDING_MODEL=qwen3-embedding:0.6b
GEMINI_API_KEY=

# N8n API Configuration
N8N_API_URL=http://localhost:5678/api/v1
N8N_API_KEY=your_n8n_api_key

# Worker Configuration
N8N_WORKER_CONCURRENCY=5
N8N_WORKER_TIMEOUT=300000
N8N_WORKER_RETRY_ATTEMPTS=3

# Scaling Configuration
ENABLE_WORKER_SCALING=true
N8N_MIN_WORKERS=1
N8N_MAX_WORKERS=10
N8N_QUEUE_THRESHOLD=20

# Memory Limits
N8N_WORKER_MEMORY_LIMIT=512

# Logging
LOG_LEVEL=info
ENABLE_ELASTICSEARCH_LOGGING=false
ELASTICSEARCH_URL=http://localhost:9200

# Security
API_KEY_SECRET=your_api_key_secret
JWT_SECRET=your_jwt_secret
ENCRYPTION_KEY=your_32_char_encryption_key

# OpenRouter — powers LLM chunking strategies (summarize / smart / headers / faq)
OPENROUTER_API_KEY=
CHUNKING_LLM_MODEL=openai/gpt-4o-mini
