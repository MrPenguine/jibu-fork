{
  "name": "worker",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/worker",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "tsc -p apps/worker/tsconfig.json"
        ],
        "parallel": false
      },
      "outputs": ["{options.outputPath}"]
    },
    "worker": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ts-node -r tsconfig-paths/register --project apps/worker/tsconfig.worker.json apps/worker/src/main.ts"
      }
    }
  }
}
