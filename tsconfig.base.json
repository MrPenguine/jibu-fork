{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@backend/*": ["apps/backend/src/*"],
      "@frontend/*": ["apps/frontend/src/*"],
      "@jibu/core/chunking": ["libs/core/chunking/src/index.ts"],
      "@jibu/core/embedding": ["libs/core/embedding/src/index.ts"],
      "@jibu/core/vector-db": ["libs/core/vector-db/src/index.ts"],
      "@jibu/queue-definitions": ["libs/queue-definitions/src/index.ts"],
      "@libs/shadcn-ui": ["libs/shadcn-ui/src/index.ts"],
      "@libs/shadcn-ui/components/*": ["libs/shadcn-ui/src/components/*"],
      "@libs/shadcn-ui/hooks/*": ["libs/shadcn-ui/src/hooks/*"],
      "@libs/shadcn-ui/lib/*": ["libs/shadcn-ui/src/lib/*"],
      "@worker/*": ["apps/worker/src/*"],
      "libs": ["libs/src/index.ts"],
      "libs/shadcn-ui/src/*": ["libs/shadcn-ui/src/*"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
